# Database
DATABASE_URL=postgresql+asyncpg://chartapp:localpass@db:5432/chartapp

# App
SECRET_KEY=change-me-to-a-random-256-bit-secret
APP_NAME=ChartAlert
APP_URL=http://localhost:8000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# Plans
FREE_ALERTS_PER_DAY=10
PRO_ALERTS_PER_DAY=500

# Playwright
PLAYWRIGHT_TIMEOUT_MS=15000
SCREENSHOT_WAIT_MS=4000
SCREENSHOT_CONCURRENCY=2

# Redis (optional - leave blank to use in-memory asyncio.Queue)
REDIS_URL=

# Worker mode (set to "worker" to run as standalone worker process)
RUN_MODE=api
